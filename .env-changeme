
COMPOSE_PROJECT_NAME=elabs-https-nginx-proxy

# SWAG / General
DOMAIN=labs.elasticlabs.co
CERTBOT_EMAIL=admin@labs.elasticlabs.co
PUID=1000
PGID=1000
CONFIG_PATH=./config

# Authentik
AUTHENTIK_SECRET_KEY=change_me_super_secret
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASSWORD=change_me_db_password
AUTHENTIK_DB_NAME=authentik

# Authentik Outpost (Proxy) - set after creating an outpost in Authentik UI
AUTHENTIK_HOST=http://authentik:9000
AUTHENTIK_OUTPOST_TOKEN=put_outpost_token_here
AUTHENTIK_INSECURE=true

# Code Server
CODE_SERVER_PASSWORD=change_me_code_password

# Restic Backup
RESTIC_PASSWORD=change_me_restic_password
BACKUP_CRON=0 3 * * *
RESTIC_FORGET_ARGS=--keep-daily 7 --keep-weekly 4 --keep-monthly 3
