COMPOSE_PROJECT_NAME=elabs-revproxy
BASE_DOMAIN=elasticlabs.co
ADMIN_EMAIL=admin@elasticlabs.co

REVPROXY_APPS_NETWORK=revproxy_apps
SWAG_NETWORK=swag_net

TZ=Europe/Paris
PUID=1000
PGID=1000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

SWAG_URL=${BASE_DOMAIN}
SWAG_SUBDOMAINS=auth,admin,labs
SWAG_VALIDATION=http
SWAG_ONLY_SUBDOMAINS=true
SWAG_STAGING=false

KEYCLOAK_VERSION=26.5.7
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_HOSTNAME=https://auth.${BASE_DOMAIN}

# Keycloak realm bootstrap
# If you modify this, please change the "realm" property in ./keycloak/import/elabs-realm.json too
KEYCLOAK_REALM=elabs

# Social login broker
KEYCLOAK_GOOGLE_CLIENT_ID=CHANGE_ME
KEYCLOAK_GOOGLE_CLIENT_SECRET=CHANGE_ME

OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_CLIENT_SECRET=CHANGE_ME
# Must decode to 16, 24 or 32 bytes. Generated automatically by `make secrets-bootstrap`.
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME
# Setup first to protect the canary container under labs subdomain
OAUTH2_PROXY_REDIRECT_URL=https://labs.${BASE_DOMAIN}/oauth2/callback
OAUTH2_PROXY_COOKIE_DOMAINS=.${BASE_DOMAIN}
OAUTH2_PROXY_WHITELIST_DOMAINS=.${BASE_DOMAIN}