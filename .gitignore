# --- environment ---
.env
.env.*
!.env-changeme

# --- secrets / local bootstrap ---
tmp/*
.tmp/*
!tmp/.gitkeep

# --- generic runtime / logs ---
*.log
*.log.*
*.pid
*.tmp
*.bak
*.swp
.DS_Store

# --- IDE ---
.vscode/
.idea/

# --- auth / generated sensitive files ---
swag/config/nginx/.htpasswd
swag/config/keys/cert.crt
swag/config/keys/cert.key

# --- letsencrypt runtime state ---
swag/config/etc/letsencrypt/
swag/config/log/
swag/config/fail2ban/fail2ban.sqlite3

# --- observability runtime data ---
grafana/data/
grafana/grafana/data/
grafana/loki/data/
grafana/prometheus/data/
grafana/tempo/data/

loki/data/
prometheus/data/
tempo/data/

# --- service runtime data ---
filebrowser/*
!filebrowser/.gitkeep

keycloak/data/
portainer/data/

# --- optional local runtime dirs if present ---
grafana/provisioning/alerting/.state/

# --- client stack local reverse proxy configs ---
swag/config/nginx/client-stacks/*
!swag/config/nginx/client-stacks/.gitkeep
!swag/config/nginx/client-stacks/*.example

# --- local client subdomain configs ---
swag/config/nginx/site-confs/client-*.subdomain.conf
!swag/config/nginx/site-confs/client-stack.subdomain.conf.example

# --- local SWAG site confs ---
swag/config/nginx/site-confs/admin.subdomain.conf
swag/config/nginx/site-confs/labs.subdomain.conf

# Keep versioned examples
!swag/config/nginx/site-confs/*.sample