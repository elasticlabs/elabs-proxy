# swag/config/nginx/site-confs/client-stack.subdomain.conf.example
#
# Example client stack exposed as a dedicated subdomain.
# Copy this file to:
#   swag/config/nginx/site-confs/my-client.subdomain.conf
#
# Then update:
#   - server_name
#   - upstream service name
#   - upstream port
#
# server {
#     listen 443 ssl;
#     listen [::]:443 ssl;
#
#     server_name my-client.__BASE_DOMAIN__;
      # Local / downstream client stacks
      include /config/nginx/client-stacks/*.conf;

